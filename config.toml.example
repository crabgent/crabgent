# crabgent example configuration.
#
# Copy to `config.toml`, create `./data`, and fill in the placeholders.
# The CLI takes `--config`; default is `./config.toml`.

sqlite_path = "./data/crabgent.sqlite"

[openai]
# Default: use `crabgent openai-login`, which stores an OAuth token at
# the default path below. Uncomment `api_key` only when using a normal API key.
# token_path = "~/.config/crabgent/credentials/openai_oauth_token"
# api_key = "sk-..."

[memory]
persist_hook = true
auto_recall = false

[mcp_server]
bind = "127.0.0.1:3100"

[web]
auth_token = "change-me"

[[agents]]
name = "local"
provider = "openai"
model = "gpt-5.5"
reasoning_effort = "low"
system_prompt = "You are a helpful local assistant. Reply in German."
max_turns = 16
holidays_country = "DE"
holidays_subdivision = "NW"
tui_bearer_token = "local-tui-token-change-me"

# Optional. Enable only for a trusted local single-user assistant.
[agents.tmux]
enabled = false
default_window = "main"

